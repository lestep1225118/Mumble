{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": "dist",
  "installCommand": "echo 'Skip npm on Vercel — production UI is frontend/ via Flask.'",
  "buildCommand": "mkdir -p dist && echo '{}' > dist/.vercel-output-marker.json",
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{node_modules/**,.testvenv/**,venv/**,.venv/**,src/**}"
    }
  }
}
